# ── App ──────────────────────────────────────────────────────────────────────
DEBUG=false
FRONTEND_URL=http://localhost:3010

# ── MongoDB ──────────────────────────────────────────────────────────────────
# Format: mongodb+srv://username:password@cluster.mongodb.net/...
MONGODB_URL=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=ankitube_learn

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRE_MINUTES=10080

# ── AI — Gemini ───────────────────────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here
LLM_MODEL_FREE=gemini-2.0-flash
LLM_MODEL_FLUENTE=gemini-1.5-pro

# ── AI — OpenRouter ────────────────────────────────────────────────────────
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL_OPENROUTER=openrouter/auto

# ── AI — Nvidia NIM (Primary for dual-role routing) ────────────────────────────
# Get from: https://build.nvidia.com
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
LLM_MODEL_NVIDIA_CURATOR_PRIMARY=meta/llama-3.3-70b-instruct
LLM_MODEL_NVIDIA_CURATOR_SECONDARY=meta/llama-3.1-70b-instruct
LLM_MODEL_NVIDIA_DESIGNER_PRIMARY=meta/llama-3.3-70b-instruct
LLM_MODEL_NVIDIA_DESIGNER_SECONDARY=nvidia/nemotron-ultra-253b
LLM_MODEL_NVIDIA_DESIGNER_TERTIARY=qwen/qwen3-next-80b-a3b-instruct

# ── AI — Role-based Fallback Chains ────────────────────────────────────────────
# Comma-separated provider keys for each role
CURATOR_FALLBACK_CHAIN=nvidia_curator_primary,nvidia_curator_secondary,openrouter,flash
DESIGNER_FALLBACK_CHAIN=nvidia_designer_primary,nvidia_designer_secondary,nvidia_designer_tertiary,openrouter,flash

# ── AI — Anthropic ────────────────────────────────────────────────────────────
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here
LLM_MODEL_NATIVO=claude-sonnet-4-20250514

# ── Superadmin 2FA ────────────────────────────────────────────────────────────
SUPERADMIN_2FA_CODE=your_6_digit_code

# ── Freemium limits ───────────────────────────────────────────────────────────
FREE_MAX_CARDS=15
FREE_MAX_DECKS_PER_DAY=1
